# Odds snapshots consumed by web/app.js (closing/market/consensus/bovada)
!data/processed/closing_lines_*.csv
!data/processed/market_*.csv
!data/processed/odds_*.csv
!data/processed/game_odds_*.csv
# Props artifacts
!data/processed/props_edges_*.csv
!data/processed/props_recommendations_*.csv
!data/processed/props_predictions_*.csv
!data/processed/reliability_props.csv
!data/processed/reliability_props_summary.json
!data/processed/reliability_props_summary.md
# Period lines (quarters/halves) consumed by web/app.js
!data/processed/period_lines_*.csv
!data/processed/period_lines_synthetic.csv
# Season schedule for UI
!data/processed/schedule_*.json
# Additional PBP-derived and diagnostics artifacts we want committed
!data/processed/pbp_reconcile_*.csv

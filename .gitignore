# Evaluation compare outputs (health/alerts/weekly summaries)
!data/processed/props_eval_compare_*.csv
!data/processed/props_eval_compare_*.json
!data/processed/props_eval_compare_*.md

# Totals/quarters calibration artifacts used to tune the PBP sim inputs
# Note: these remain ignored by default to avoid clutter; the commit script
# force-adds the needed files when publishing.

# SmartSim artifacts (used for props derivation + diagnostics)
!data/processed/smart_sim_*.json
!data/processed/daily_artifacts_*.json

# Note: exclude PBP-derived predictions/outcomes from git to keep Render pushes light
# (these are used only for offline backtests/validation and not consumed by the frontend)
# If needed locally, they remain available on disk and via CI artifacts.

# Game cards (frontend consumption)
!data/processed/game_cards_*.csv
# PBP: first-basket recommendations (frontend consumption)
!data/processed/first_basket_recs_*.csv

# Legacy root predictions snapshot (not used by Render UI)
predictions.csv

# Local-only / scratch outputs (do not commit)
_tmp_game_cards_*.json
tmp_smoke_endpoints*.py

# Local backtest / walkforward artifacts (keep out of git)
# Note: these match the whitelisted `props_edges_*.csv` prefix, so we explicitly re-ignore them.
data/processed/props_edges_backtest*.csv
data/processed/props_edges_walkforward*.csv

# Local SmartSim diagnostics (not consumed by the frontend)
data/processed/smart_sim_merge_report_*.json

# SmartSim artifacts: ignore by default (they're large/noisy locally).
# Publishing script force-adds the daily SmartSim files when needed for Render parity.
data/processed/smart_sim_*.json

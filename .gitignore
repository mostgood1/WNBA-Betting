.http_cache.sqlite

# Temporary and scratch files/scripts
temp_*.py

# Quarantined scratch utilities (kept locally, not versioned)
tools/_scratch/
scripts/_scratch/

# Local backtest outputs
processed/

# Ignore most processed data by default; whitelist site-facing daily artifacts
data/processed/**
!data/processed/
# Game predictions and publishables
!data/processed/games_predictions_npu_*.csv
!data/processed/predictions_*.csv
!data/processed/recommendations_*.csv
!data/processed/recon_games_*.csv

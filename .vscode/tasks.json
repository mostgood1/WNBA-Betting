{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Flask app",
			"type": "shell",
			"command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
			"args": [
				"app.py"
			],
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "Cron: run-all (today)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\run_cron.ps1"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Daily: local update (props + predictions)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\daily_update.ps1",
				"-GitPush",
				"-Token",
				"${env:CRON_TOKEN}"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Props: edges (today, auto)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$d = Get-Date -Format 'yyyy-MM-dd'; & '${workspaceFolder}\\.venv\\Scripts\\python.exe' -m nba_betting.cli props-edges --date $d --source auto"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Schedule: register daily local updater",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\register_daily_task.ps1",
				"-Time",
				"10:00",
				"-GitPush"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Schedule: unregister daily local updater",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\unregister_daily_task.ps1"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Run Flask locally on port 5051",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$env:PORT='5051'; & '${workspaceFolder}\\.venv\\Scripts\\python.exe' app.py"
			],
			"isBackground": true,
			"problemMatcher": [
				"$eslint-stylish"
			],
			"group": "build"
		},
		{
			"label": "Backfill: two years (finals-only)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\backfill_two_years.ps1",
				"-Start",
				"2023-10-01",
				"-End",
				"2025-10-26"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		}
		,
		{
			"label": "Backfill: weekly (21d, finals-only)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\weekly_backfill.ps1",
				"-Days",
				"21",
				"-FinalsOnly"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build",
			"detail": "Runs PBP + reconcile-quarters backfill over the last 21 days."
		},
		{
			"label": "Schedule: register weekly backfill",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\register_weekly_backfill_task.ps1",
				"-DayOfWeek",
				"Monday",
				"-Time",
				"09:30",
				"-Days",
				"21",
				"-FinalsOnly"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Schedule: unregister weekly backfill",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\unregister_weekly_backfill_task.ps1"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Eval: rollup metrics (last 30 days)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"& '${workspaceFolder}\\.venv\\Scripts\\python.exe' '${workspaceFolder}\\tools\\evaluate_models.py' --days 30"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Data: commit processed (today)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\commit_processed.ps1",
				"-Date",
				"$(Get-Date -Format 'yyyy-MM-dd')",
				"-IncludeJson",
				"-Push"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Data: commit processed (pick date)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\commit_processed.ps1",
				"-Date",
				"${input:commitDate}",
				"-IncludeJson",
				"-Push"
			],
			"isBackground": false,
			"problemMatcher": []
		}
		,
		{
			"label": "Train: enhanced models -> ONNX",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"& '${workspaceFolder}\\.venv\\Scripts\\python.exe' -m nba_betting.cli train-games-enhanced-onnx"
			],
			"isBackground": false,
			"problemMatcher": [],
			"detail": "Run on x86_64 where scikit-learn wheels are available; produces *_enhanced.onnx in models/."
		}
	],
	"inputs": [
		{
			"id": "commitDate",
			"type": "promptString",
			"description": "Enter date to commit (yyyy-MM-dd)",
			"default": "$(Get-Date -Format 'yyyy-MM-dd')"
		}
	]
}
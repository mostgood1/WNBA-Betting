{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Flask app",
			"type": "shell",
			"command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
			"args": [
				"app.py"
			],
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "Health: warm caches (today)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$env:NBA_API_BASE_URL='http://127.0.0.1:5051'; $d = Get-Date -Format 'yyyy-MM-dd'; $env:NBA_DATE=$d; & '${workspaceFolder}\\.venv\\Scripts\\python.exe' '${workspaceFolder}\\tools\\warm_caches.py'"
			],
			"isBackground": false,
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Schedule: register warm caches (01:55)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\register_cache_warmer_task.ps1",
				"-Time",
				"01:55"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Schedule: unregister warm caches",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\unregister_cache_warmer_task.ps1"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Cron: run-all (today)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\run_cron.ps1"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Daily: local update (props + predictions)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\daily_update.ps1",
				"-GitPush",
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Props: edges (today, auto)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$d = Get-Date -Format 'yyyy-MM-dd'; & '${workspaceFolder}\\.venv\\Scripts\\python.exe' -m nba_betting.cli props-edges --date $d --source auto"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Schedule: register daily local updater",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\register_daily_task.ps1",
				"-Time",
				"10:00",
				"-GitPush"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Schedule: unregister daily local updater",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\unregister_daily_task.ps1"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Run Flask locally on port 5051",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"& '${workspaceFolder}\\.venv\\Scripts\\python.exe' -m waitress --listen=0.0.0.0:5051 app:app"
			],
			"isBackground": true,
			"problemMatcher": [
				"$eslint-stylish"
			],
			"group": "build"
		},
		{
			"label": "Backfill: two years (finals-only)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\backfill_two_years.ps1",
				"-Start",
				"2023-10-01",
				"-End",
				"2025-10-26"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Backfill: weekly (21d, finals-only)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\weekly_backfill.ps1",
				"-Days",
				"21",
				"-FinalsOnly"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build",
			"detail": "Runs PBP + reconcile-quarters backfill over the last 21 days."
		},
		{
			"label": "Schedule: register weekly backfill",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\register_weekly_backfill_task.ps1",
				"-DayOfWeek",
				"Monday",
				"-Time",
				"09:30",
				"-Days",
				"21",
				"-FinalsOnly"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Schedule: unregister weekly backfill",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\unregister_weekly_backfill_task.ps1"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Metrics: simulation alignment report",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$d = Get-Date -Format 'yyyy-MM-dd'; & '${workspaceFolder}\\.venv\\Scripts\\python.exe' '${workspaceFolder}\\tools\\simulation_alignment_report.py' --date $d --windows 30,60,90 --outdir '${workspaceFolder}\\data\\processed\\metrics'"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Metrics: validate simulated data",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"& '${workspaceFolder}\\.venv\\Scripts\\python.exe' '${workspaceFolder}\\tools\\validate_simulated_data.py' --outdir '${workspaceFolder}\\data\\processed\\metrics'"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Metrics: drift monitor (games)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$d = Get-Date -Format 'yyyy-MM-dd'; & '${workspaceFolder}\\.venv\\Scripts\\python.exe' '${workspaceFolder}\\tools\\drift_monitor.py' --date $d --ref-days 30 --cur-days 7"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Metrics: sensitivity sweep (corr)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$d = Get-Date -Format 'yyyy-MM-dd'; & '${workspaceFolder}\\.venv\\Scripts\\python.exe' '${workspaceFolder}\\tools\\sensitivity_sweep_corr.py' --base-url 'http://127.0.0.1:5051' --date $d --scales '0.0,0.5,1.0,1.5,2.0' --outdir '${workspaceFolder}\\data\\processed\\metrics'"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Schedule: register nightly metrics",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\register_nightly_metrics_task.ps1",
				"-Time",
				"02:00"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Schedule: unregister nightly metrics",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\unregister_nightly_metrics_task.ps1"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Eval: rollup metrics (last 30 days)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"& '${workspaceFolder}\\.venv\\Scripts\\python.exe' '${workspaceFolder}\\tools\\evaluate_models.py' --days 30"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Eval: reliability (last 60 days)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"& '${workspaceFolder}\\.venv\\Scripts\\python.exe' -m nba_betting.cli evaluate-reliability --days 60 --bins 10"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Calibrate: games market blend (apply today)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$d = Get-Date -Format 'yyyy-MM-dd'; & '${workspaceFolder}\\.venv\\Scripts\\python.exe' '${workspaceFolder}\\tools\\games_blend.py' --train-days 30 --apply-date $d"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Data: commit processed (today)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$d = Get-Date -Format 'yyyy-MM-dd'; & '${workspaceFolder}\\scripts\\commit_processed.ps1' -Date $d -IncludeJson -Push"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Data: commit processed (pick date)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\commit_processed.ps1",
				"-Date",
				"${input:commitDate}",
				"-IncludeJson",
				"-Push"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Train: enhanced models -> ONNX",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"& '${workspaceFolder}\\.venv\\Scripts\\python.exe' -m nba_betting.cli train-games-enhanced-onnx"
			],
			"isBackground": false,
			"problemMatcher": [],
			"detail": "Run on x86_64 where scikit-learn wheels are available; produces *_enhanced.onnx in models/."
		},
		{
			"label": "Backfill: predictions 60 days",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\backfill_predictions_60_days.ps1"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Odds: snapshot (today)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$d = Get-Date -Format 'yyyy-MM-dd'; & '${workspaceFolder}\\.venv\\Scripts\\python.exe' -m nba_betting.cli odds-snapshots --date $d"
			],
			"isBackground": false,
			"group": "build"
		}
		,
		{
			"label": "Odds: closing lines (today)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$d = Get-Date -Format 'yyyy-MM-dd'; $env:NBA_DATE=$d; & '${workspaceFolder}\\.venv\\Scripts\\python.exe' '${workspaceFolder}\\tools\\capture_games_closing_lines.py'"
			],
			"isBackground": false,
			"group": "build",
			"detail": "Captures closing/consensus lines for games and writes closing_lines_<date>.csv (frontend-compatible)."
		}
		,
		{
			"label": "Backtest: props portfolio (last 60 days)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"& '${workspaceFolder}\\.venv\\Scripts\\python.exe' '${workspaceFolder}\\tools\\backtest_portfolio.py' --days 60 --limit 10"
			],
			"isBackground": false,
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Backtest: props portfolio (30d optimized)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"& '${workspaceFolder}\\.venv\\Scripts\\python.exe' '${workspaceFolder}\\tools\\backtest_portfolio.py' --days 30 --limit 12 --optimize --corr-penalty-scale 1.2 --cap-team 2 --cap-market 3"
			],
			"isBackground": false,
			"group": "build",
			"problemMatcher": [],
			"detail": "Uses optimizer with correlation penalties and diversification caps."
		}
		,
		{
			"label": "Backtest: optimizer sweep (quick)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"& '${workspaceFolder}\\.venv\\Scripts\\python.exe' '${workspaceFolder}\\tools\\sweep_portfolio_optimizer.py' --days 30 --limits '10,12' --corr-scales '0.0,0.8,1.2' --cap-teams '1,2' --cap-markets '3'"
			],
			"isBackground": false,
			"group": "build",
			"problemMatcher": [],
			"detail": "Sweeps optimizer params over a small grid and writes results under data/processed/backtests/."
		}
		,
		{
			"label": "Calibrate: props probability (from reliability bins)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"& '${workspaceFolder}\\.venv\\Scripts\\python.exe' '${workspaceFolder}\\tools\\calibrate_props_probability.py'"
			],
			"isBackground": false,
			"problemMatcher": []
		}
		,
		{
			"label": "Calibrate: props probability (windows 30/60/90)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"& '${workspaceFolder}\\.venv\\Scripts\\python.exe' '${workspaceFolder}\\tools\\calibrate_props_probability_multi.py'"
			],
			"isBackground": false,
			"group": "build",
			"problemMatcher": []
		}
		,
		{
			"label": "Health: ping endpoints",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\health_check_endpoints.ps1"
			],
			"isBackground": false,
			"group": "build",
			"problemMatcher": []
		}
		,
		{
			"label": "Schedule: register nightly props calibration",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\register_nightly_calibration_task.ps1",
				"-Time",
				"23:15"
			],
			"isBackground": false,
			"problemMatcher": []
		}
		,
		{
			"label": "Schedule: register nightly games closing",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\register_nightly_games_closing_task.ps1",
				"-Time",
				"01:50"
			],
			"isBackground": false,
			"problemMatcher": []
		}
		,
		{
			"label": "Schedule: unregister nightly games closing",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\unregister_nightly_games_closing_task.ps1"
			],
			"isBackground": false,
			"problemMatcher": []
		}
		,
		{
			"label": "Calibrate: games probability (last 60 days)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"& '${workspaceFolder}\\.venv\\Scripts\\python.exe' '${workspaceFolder}\\tools\\calibrate_games_probability.py' --days 60 --bins 10"
			],
			"isBackground": false,
			"problemMatcher": []
		}
		,
		{
			"label": "Schedule: unregister nightly props calibration",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\unregister_nightly_calibration_task.ps1"
			],
			"isBackground": false,
			"problemMatcher": []
		}
	],
	"inputs": [
		{
			"id": "commitDate",
			"type": "promptString",
			"description": "Enter date to commit (yyyy-MM-dd)",
			"default": "$(Get-Date -Format 'yyyy-MM-dd')"
		}
	]
}
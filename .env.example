# Copy this file to .env and fill in your keys
# OddsAPI: https://the-odds-api.com/
ODDS_API_KEY=your_key_here

# Live player props OddsAPI refresh throttles (server-side caches)
# - LIVE_PLAYER_PROPS_ODDS_TTL_SEC controls how often live prop lines can refresh
# - event/market discovery are cached much longer to avoid extra requests
LIVE_PLAYER_PROPS_ODDS_TTL_SEC=30
# LIVE_PLAYER_PROPS_EVENT_TTL_SEC=21600
# LIVE_PLAYER_PROPS_MARKETS_TTL_SEC=1800

# Optional: where to persist Live Lens JSONL logs + tuning override.
# Default (if unset): data/processed
# Render suggestion (requires persistent disk): /opt/render/project/data/live_lens
# NBA_LIVE_LENS_DIR=
